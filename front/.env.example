# ============================================================
# .env.example — ローカル開発用の環境変数テンプレート
# 使い方: `cp .env.example .env` してから各値を設定する
# （.env は .gitignore 済み。秘密情報はコミットしないこと）
# ここに並ぶ 9 変数がアプリ（src/）が実際に読み込む全てです。
# ============================================================

# 実行環境: development / production
NODE_ENV=development

# CORS 許可オリジン（フロントの公開URL）。ローカルは http://localhost:3000
ALLOWED_ORIGIN=http://localhost:3000

# --- Google Cloud Storage（コンテンツデータ。DBは使わない）---
# 取得元: GCP コンソール → Cloud Storage。プライベートバケット名
GCS_PRIVATE_BUCKET_NAME=
# バケット内の各 JSON ファイルへのパス（オブジェクト名）
GCS_COMMON_DATA_PATH=
GCS_PERSONAL_DATA_PATH=
GCS_SAMPLE_DATA_PATH=

# --- メール送信（お問い合わせフォーム / Resend）---
# 送信先（自分の受信用）メールアドレス
MY_MAIL_ADDRESS=
# 取得元: https://resend.com/ の API Keys
RESEND_API_KEY=
# Resend で認証済みの送信ドメイン
RESEND_SEND_DOMAIN=

# 注: BACKEND_API_URL / API_VALIDATE_SECRET_TOKEN / API_SECRET_TOKEN /
#     NEXT_PUBLIC_API_TOKEN は現行コードでは未使用（レガシー）。
#     詳細は docs/10-miscellaneous-specification.md を参照。
